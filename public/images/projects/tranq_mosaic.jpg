<script>
(function(){
  /* ========= CONFIG MULTI-CLASSE + BREAKPOINT =========
     Per ogni selettore imposta i parametri DESKTOP e MOBILE.
     - start: frazione viewport dove la riga è "vuota" (tipico 1.0 = bordo basso)
     - finish: frazione viewport dove la PRIMA riga è "piena" (es. 0.75 = 75% dall'alto)
  */
  const ROOT_SELECTORS = [
    {
      sel: '.scroll-gradient-lines',
      desktop: { start: 1.00, finish: 0.65 },
      mobile:  { start: 1.00, finish: 0.80 }
    },
    {
      sel: '.scroll-gradient-absolute-lines',
      desktop: { start: 1.00, finish: 0.80 },
      mobile:  { start: 1.00, finish: 0.80 }
    },
    {
      sel: '.scroll-grey-lines',
      desktop: { start: 1.00, finish: 0.70 },
      mobile:  { start: 1.00, finish: 0.80 }
    }
  ];

  const BREAKPOINT = 768;   // <768px = mobile
  const BUCKET     = 2;     // quantizzazione px per raggruppare parole sulla stessa riga

  const $$ = (sel, root=document) => Array.from(root.querySelectorAll(sel));
  const clamp01 = v => Math.max(0, Math.min(1, v));

  /* Wrappa SOLO text nodes in <span class="sgl-word"> preservando tag/stili */
  function wrapWordsPreserve(el){
    if (el.dataset.sglWrapped) return;
    const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, {
      acceptNode(n){
        if (!n.nodeValue || !n.nodeValue.trim().length) return NodeFilter.FILTER_REJECT;
        const p = n.parentNode && n.parentNode.nodeName;
        if (p === 'SCRIPT' || p === 'STYLE') return NodeFilter.FILTER_REJECT;
        return NodeFilter.FILTER_ACCEPT;
      }
    });
    const nodes = [];
    while (walker.nextNode()) nodes.push(walker.currentNode);

    nodes.forEach(textNode=>{
      const frag = document.createDocumentFragment();
      textNode.nodeValue.split(/(\s+)/).forEach(part=>{
        if (!part) return;
        if (/^\s+$/.test(part)) {
          frag.appendChild(document.createTextNode(part)); // preserva spazi
        } else {
          const span = document.createElement('span');
          span.className = 'sgl-word';
          span.textContent = part;
          frag.appendChild(span);
        }
      });
      textNode.parentNode.replaceChild(frag, textNode);
    });

    el.dataset.sglWrapped = 'true';
  }

  /* Raggruppa parole per riga (ordinate da sx→dx), usando offsetTop/Left/Width (stabile) */
  function groupLines(el){
    const words = $$('.sgl-word', el);
    const rows = new Map();
    words.forEach(w=>{
      const y = Math.round((w.offsetTop || 0)/BUCKET)*BUCKET;
      (rows.get(y) ?? rows.set(y, []).get(y)).push(w);
    });
    return Array.from(rows.values())
      .map(line => line.sort((a,b)=>a.offsetLeft - b.offsetLeft));
  }

  /* Aggiorna un singolo elemento con parametri start/finish */
  function updateEl(el, startAt, finishAt){
    const vh = window.innerHeight || document.documentElement.clientHeight;
    const baseStartY  = vh * startAt;   // posizione (px) dove la riga è "vuota"
    const baseFinishY = vh * finishAt;  // posizione (px) dove la PRIMA riga è "piena"
    const windowPx    = Math.max(1, baseStartY - baseFinishY);

    // progress globale g: 0→1 riempie riga 0; 1→2 riempie riga 1; ecc. (effetto "staffetta")
    const blockTop = el.getBoundingClientRect().top;
    const g = (baseStartY - blockTop) / windowPx;

    const lines = groupLines(el);
    lines.forEach((words, i)=>{
      if (!words.length) return;

      // ratio per riga i: parte quando g>=i, finisce quando g>=i+1
      const ratio = clamp01(g - i);

      // dimensioni riga in px
      const first = words[0];
      const last  = words[words.length-1];
      const lineLeft  = first.offsetLeft;
      const lineRight = last.offsetLeft + last.offsetWidth;
      const lineW     = Math.max(1, lineRight - lineLeft);
      const fillPx    = Math.round(lineW * ratio);

      // allinea il gradiente su ogni parola in base all'offset nella riga
      words.forEach(w=>{
        const offsetInLine = w.offsetLeft - lineLeft;
        w.style.backgroundSize     = ⁠ ${fillPx}px 100%, ${w.offsetWidth}px 100% ⁠;
        w.style.backgroundPosition = ⁠ ${-offsetInLine}px 0, 0 0 ⁠;
      });
    });
  }

  /* Aggiorna tutte le classi configurate con i parametri corretti per viewport */
  function updateAll(){
    const isMobile = window.innerWidth < BREAKPOINT;
    ROOT_SELECTORS.forEach(cfg=>{
      const params = isMobile ? cfg.mobile : cfg.desktop;
      document.querySelectorAll(cfg.sel).forEach(el=>{
        updateEl(el, params.start, params.finish);
      });
    });
  }

  /* Init: wrap parole e primo update */
  function init(){
    ROOT_SELECTORS.forEach(cfg=>{
      document.querySelectorAll(cfg.sel).forEach(wrapWordsPreserve);
    });
    updateAll();
  }

  // Eventi
  window.addEventListener('scroll', updateAll, { passive:true });
  window.addEventListener('resize', updateAll);
  document.addEventListener('DOMContentLoaded', init);

  // Aspetta i font per misure corrette
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(updateAll).catch(()=>{});
  }

  // Doppio RAF per stabilizzare il layout iniziale
  requestAnimationFrame(()=>requestAnimationFrame(updateAll));
})();
</script>
